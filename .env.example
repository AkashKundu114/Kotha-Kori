# --- WhatsApp Cloud API (Meta) ---
# From developers.facebook.com > your app > WhatsApp > API Setup
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
# You choose this string yourself, then enter the SAME value in
# Meta's webhook config screen (hub.verify_token)
WA_WEBHOOK_VERIFY_TOKEN=
# Meta App Dashboard > Settings > Basic > App Secret
# (NOT the same as WA_WEBHOOK_VERIFY_TOKEN above — this signs the webhook payload)
WA_APP_SECRET=

# --- Postgres / Redis (local containers, just set passwords) ---
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://kothkori:changeme@postgres:5432/kothkori
REDIS_URL=redis://:changeme@redis:6379/0

# --- Object storage (S3-compatible; DigitalOcean Spaces default) ---
S3_BUCKET=kotha-khata-assets
AWS_REGION=blr1
S3_ENDPOINT_URL=https://blr1.digitaloceanspaces.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================
# STRONGLY RECOMMENDED — cuts your OpenAI spend significantly
# ============================================================

# Sarvam AI (sarvam.ai) — cheap, Bengali-native primary tier for all
# structured text (ledger extraction, corrections, captions, market
# phrasing) and for Bengali<->English translation. Leave blank and the
# bot still works — everything just routes to OpenAI instead, at higher
# cost per message. Get a key + free ₹100 signup credit at sarvam.ai.
SARVAM_API_KEY=
SARVAM_CHAT_MODEL=sarvam-30b

# ============================================================
# OPTIONAL — safe to leave blank/default
# ============================================================

# Free, self-hosted fallback tier(s) — no third-party API, run in your
# own infra. Off by default; turn on only if you have a GPU box.
USE_LOCAL_MODELS=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
ROUTINE_CONFIDENCE_FLOOR=0.80
# Your own Q4-quantized sarvam-translate box, served OpenAI-compatible
# (e.g. `vllm serve sarvamai/sarvam-translate`). Blank = disabled.
SARVAM_LOCAL_BASE_URL=

# Bengali-glyph TTF for ad-poster text overlay. See assets/fonts/README.md.
BENGALI_FONT_PATH=assets/fonts/NotoSansBengali-VariableFont_wdth,wght.ttf

# Government mandi price feed for Feature 8 (Market Predictor).
# Optional — market predictor still works off ledger data alone if blank.
DATA_GOV_IN_API_KEY=

# Observability (self-hosted Langfuse). Optional — leave blank to skip.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

DEBUG=false
MAX_MESSAGES_PER_HOUR=30
SESSION_TTL_SECONDS=1800
